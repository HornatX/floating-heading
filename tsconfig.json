{
  "compilerOptions": {
    "target": "ES2022",                  // <--- 改成 ES2022 或 ES2020
    "lib": ["DOM", "ES2022"],            // <--- 确保这里有较新的 ES 库
    "module": "CommonJS",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"]
}